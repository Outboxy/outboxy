{
  "name": "@outboxy/db-adapter-postgres",
  "version": "0.1.1",
  "private": true,
  "description": "PostgreSQL database adapter for Outboxy",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@outboxy/db-adapter-core": "workspace:*",
    "@outboxy/migrations": "workspace:*",
    "@outboxy/schema": "workspace:*",
    "@outboxy/logging": "workspace:*",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@outboxy/testing-utils": "workspace:*",
    "@types/pg": "^8.20.0",
    "pino": "^10.3.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "outbox",
    "database",
    "adapter",
    "postgresql",
    "typescript"
  ],
  "author": "Outboxy Team <team@outboxy.dev>",
  "license": "MIT",
  "homepage": "https://github.com/outboxy/outboxy#readme",
  "bugs": {
    "url": "https://github.com/outboxy/outboxy/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/outboxy/outboxy.git",
    "directory": "packages/db-adapter-postgres"
  }
}
