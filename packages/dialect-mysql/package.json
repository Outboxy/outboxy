{
  "name": "@outboxy/dialect-mysql",
  "version": "1.1.4",
  "description": "MySQL dialect for Outboxy SDK",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --watch --project tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@outboxy/dialect-core": "workspace:*",
    "@outboxy/schema": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vitest": "^4.0.0"
  },
  "keywords": [
    "outbox",
    "mysql",
    "dialect",
    "sdk"
  ],
  "author": "Outboxy Team <team@outboxy.dev>",
  "license": "MIT"
}
