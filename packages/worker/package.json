{
  "name": "@outboxy/worker",
  "version": "0.1.1",
  "private": true,
  "description": "Outboxy event worker (polling & publishing)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@outboxy/db-adapter-core": "workspace:*",
    "@outboxy/publisher-core": "workspace:*",
    "@outboxy/logging": "workspace:*",
    "pino": "^10.1.0",
    "prom-client": "^15.1.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@outboxy/testing-utils": "workspace:*",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.0"
  }
}
