{
  "name": "@outboxy/migrations",
  "version": "0.1.0",
  "private": true,
  "description": "Database migrations for Outboxy",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc --project tsconfig.build.json && pnpm copy:migrations",
    "copy:migrations": "cp -r sql dist/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "clean": "rm -rf dist node_modules",
    "migrate": "tsx src/runner.ts"
  },
  "dependencies": {
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/pg": "^8.18.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "pg": "^8.11.0",
    "mysql2": "^3.9.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    }
  },
  "keywords": [
    "outbox",
    "database",
    "migrations",
    "postgresql",
    "mysql"
  ],
  "author": "Outboxy Team <team@outboxy.dev>",
  "license": "MIT",
  "homepage": "https://github.com/outboxy/outboxy#readme",
  "bugs": {
    "url": "https://github.com/outboxy/outboxy/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/outboxy/outboxy.git",
    "directory": "packages/migrations"
  }
}
