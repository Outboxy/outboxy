  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "kafkajs": "^2.2.4",
    "mysql2": "^3.20.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@outboxy/migrations": "workspace:*",
    "@testcontainers/mysql": "^11.13.0",
    "@testcontainers/redpanda": "^11.13.0",
    "@types/pg": "^8.20.0",
    "testcontainers": "^11.13.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "vitest": "^4.1.2"
  }
}
