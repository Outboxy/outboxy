{
  "name": "@outboxy/testing-utils",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./globalSetup": {
      "types": "./dist/globalSetup.d.ts",
      "import": "./dist/globalSetup.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
