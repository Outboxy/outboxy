{
  "name": "@outboxy/logging",
  "version": "0.1.0",
  "private": true,
  "description": "Shared logging utilities for Outboxy",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc --project tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "pino-pretty": "^13.0.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  }
}
