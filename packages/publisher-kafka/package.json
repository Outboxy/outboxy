{
  "name": "@outboxy/publisher-kafka",
  "version": "0.1.1",
  "private": true,
  "description": "Kafka publisher for Outboxy",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc --project tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@outboxy/logging": "workspace:*",
    "@outboxy/publisher-core": "workspace:*",
    "kafkajs": "^2.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "outbox",
    "publisher",
    "kafka",
    "kafkajs",
    "event-streaming",
    "typescript"
  ],
  "author": "Outboxy Team <team@outboxy.dev>",
  "license": "MIT",
  "homepage": "https://github.com/outboxy/outboxy#readme",
  "bugs": {
    "url": "https://github.com/outboxy/outboxy/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/outboxy/outboxy.git",
    "directory": "packages/publisher-kafka"
  }
}
