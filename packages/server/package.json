{
  "name": "@outboxy/server",
  "version": "0.1.1",
  "private": true,
  "description": "Outboxy deployment package (API + Worker CLI, Docker build context)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "outboxy-api": "./dist/cli/api.js",
    "outboxy-worker": "./dist/cli/worker.js"
  },
  "scripts": {
    "dev:api": "tsx watch src/cli/api.ts",
    "dev:worker": "tsx watch src/cli/worker.ts",
    "build": "tsc --project tsconfig.build.json",
    "start:api": "node dist/cli/api.js",
    "start:worker": "node dist/cli/worker.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules",
    "test": "vitest run",
    "load-test": "tsx scripts/load-test.ts",
    "load-test:10k": "tsx scripts/load-test.ts --events 10000",
    "load-test:100k": "tsx scripts/load-test.ts --events 100000",
    "load-test:1m": "tsx scripts/load-test.ts --events 1000000",
    "load-test:docker": "bash scripts/load-test-docker.sh"
  },
  "dependencies": {
    "@outboxy/api": "workspace:*",
    "@outboxy/worker": "workspace:*",
    "@outboxy/db-adapter-core": "workspace:*",
    "@outboxy/db-adapter-postgres": "workspace:*",
    "@outboxy/db-adapter-mysql": "workspace:*",
    "@outboxy/publisher-core": "workspace:*",
    "@outboxy/publisher-http": "workspace:*",
    "@outboxy/publisher-kafka": "workspace:*",
    "@outboxy/schema": "workspace:*",
    "@outboxy/logging": "workspace:*",
    "@outboxy/migrations": "workspace:*",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
