{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Quick Status",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Transactions/s",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=\"$database\"}[1m]) + rate(pg_stat_database_xact_rollback{datname=\"$database\"}[1m])",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "title": "Cache Hit %",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_blks_hit{datname=\"$database\"}[5m]) / clamp_min(rate(pg_stat_database_blks_hit{datname=\"$database\"}[5m]) + rate(pg_stat_database_blks_read{datname=\"$database\"}[5m]), 1) * 100",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "title": "Dead Tuples",
      "description": "Dead tuples on $table — high values mean autovacuum is falling behind",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "pg_stat_user_tables_n_dead_tup{relname=\"$table\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 10000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "title": "Deadlocks",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "targets": [
        {
          "expr": "pg_stat_database_deadlocks{datname=\"$database\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      }
    },
    {
      "title": "Throughput Diagnostics",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Transactions",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=\"$database\"}[1m])",
          "legendFormat": "commits/s",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname=\"$database\"}[1m])",
          "legendFormat": "rollbacks/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      }
    },
    {
      "title": "Scan Efficiency ($table)",
      "description": "Sequential scans on the outbox table indicate missing or unused indexes — the #1 cause of throughput drops",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "targets": [
        {
          "expr": "rate(pg_stat_user_tables_idx_scan{relname=\"$table\"}[1m])",
          "legendFormat": "idx scans/s",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_user_tables_seq_scan{relname=\"$table\"}[1m])",
          "legendFormat": "seq scans/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "idx scans/s" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "green", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "seq scans/s" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "red", "mode": "fixed" }
              }
            ]
          }
        ]
      }
    },
    {
      "title": "Connections by State",
      "description": "Watch for idle_in_transaction pile-ups — indicates workers holding locks too long",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "targets": [
        {
          "expr": "sum by (state) (pg_stat_activity_count)",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Table Health & Write Pressure",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Dead vs Live Tuples ($table)",
      "description": "Dead tuples accumulate as rows are updated/deleted. If dead outpaces live, autovacuum can't keep up.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "targets": [
        {
          "expr": "pg_stat_user_tables_n_live_tup{relname=\"$table\"}",
          "legendFormat": "live",
          "refId": "A"
        },
        {
          "expr": "pg_stat_user_tables_n_dead_tup{relname=\"$table\"}",
          "legendFormat": "dead",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "live" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "green", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "dead" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "red", "mode": "fixed" }
              }
            ]
          }
        ]
      }
    },
    {
      "title": "Tuple Operations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_inserted{datname=\"$database\"}[1m])",
          "legendFormat": "inserted/s",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_tup_updated{datname=\"$database\"}[1m])",
          "legendFormat": "updated/s",
          "refId": "B"
        },
        {
          "expr": "rate(pg_stat_database_tup_deleted{datname=\"$database\"}[1m])",
          "legendFormat": "deleted/s",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      }
    },
    {
      "title": "Checkpoint & Buffer Activity",
      "description": "buffers_backend spikes = sync WAL writes bypassing bgwriter — causes latency spikes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "targets": [
        {
          "expr": "rate(pg_stat_bgwriter_buffers_checkpoint_total[1m])",
          "legendFormat": "checkpoint buffers/s",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_bgwriter_buffers_backend_total[1m])",
          "legendFormat": "backend buffers/s",
          "refId": "B"
        },
        {
          "expr": "rate(pg_stat_bgwriter_buffers_clean_total[1m])",
          "legendFormat": "bgwriter clean/s",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "backend buffers/s" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "red", "mode": "fixed" }
              }
            ]
          }
        ]
      }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["postgres", "load-test", "diagnostics"],
