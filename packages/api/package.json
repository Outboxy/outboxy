{
  "name": "@outboxy/api",
  "version": "0.1.0",
  "private": true,
  "description": "Outboxy REST API server (Fastify)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@fastify/swagger": "^9.6.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@outboxy/db-adapter-core": "workspace:*",
    "@outboxy/logging": "workspace:*",
    "fastify": "^5.8.3",
    "fastify-plugin": "^5.0.1",
    "pino": "^10.1.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@outboxy/db-adapter-mysql": "workspace:*",
    "@outboxy/db-adapter-postgres": "workspace:*",
    "@outboxy/testing-utils": "workspace:*",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.0"
  }
}
