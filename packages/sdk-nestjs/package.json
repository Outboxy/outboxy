{
  "name": "@outboxy/sdk-nestjs",
  "version": "2.1.5",
  "description": "NestJS integration for Outboxy transactional outbox pattern",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc --project tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@outboxy/sdk": "workspace:*"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/testing": "^11.1.17",
    "@outboxy/dialect-postgres": "workspace:*",
    "@outboxy/migrations": "workspace:*",
    "@outboxy/testing-utils": "workspace:*",
    "@types/pg": "^8.18.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "outbox",
    "pattern",
    "nestjs",
    "sdk",
    "typescript",
    "event-driven",
    "transactional"
  ],
  "author": "Outboxy Team <team@outboxy.dev>",
  "license": "MIT",
  "homepage": "https://github.com/outboxy/outboxy/tree/main/packages/sdk-nestjs#readme",
  "bugs": {
    "url": "https://github.com/outboxy/outboxy/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/outboxy/outboxy.git",
    "directory": "packages/sdk-nestjs"
  }
}
