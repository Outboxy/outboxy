# =============================================================================
# Docker Compose Configuration
# =============================================================================
# PostgreSQL credentials (used in docker-compose.yml)
POSTGRES_USER=outboxy
POSTGRES_PASSWORD=outboxy
POSTGRES_DB=outboxy
POSTGRES_PORT=5432

# =============================================================================
# Database Configuration (Required)
# =============================================================================
DATABASE_URL=postgresql://outboxy:outboxy@localhost:5432/outboxy

# =============================================================================
# API Server Configuration
# =============================================================================
PORT=3000
LOG_LEVEL=info

# =============================================================================
# Worker Configuration
# =============================================================================
POLL_INTERVAL_MS=1000
BATCH_SIZE=10
MAX_RETRIES=5
BACKOFF_BASE_MS=1000
BACKOFF_MULTIPLIER=2

# Multi-worker cluster configuration
WORKER_COUNT=1
# WORKER_ID_PREFIX=worker

# =============================================================================
# Publisher Configuration
# =============================================================================
PUBLISHER_TYPE=http
# PUBLISHER_TYPE=kafka  # Uncomment for Kafka

# Kafka Configuration (if PUBLISHER_TYPE=kafka)
# KAFKA_BROKERS=localhost:9092
# KAFKA_CLIENT_ID=outboxy-worker
# KAFKA_COMPRESSION_TYPE=gzip
# KAFKA_MAX_RETRIES=3
# KAFKA_REQUEST_TIMEOUT_MS=30000

# HTTP Publisher Configuration (if PUBLISHER_TYPE=http)
HTTP_TIMEOUT_MS=30000
